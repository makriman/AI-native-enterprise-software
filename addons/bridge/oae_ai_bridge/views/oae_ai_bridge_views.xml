<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_oae_ai_bridge_context_link_tree" model="ir.ui.view">
    <field name="name">oae.ai.bridge.context.link.tree</field>
    <field name="model">oae.ai.bridge.context.link</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="model_name"/>
        <field name="res_id"/>
        <field name="build_request_id"/>
        <field name="requested_by_id"/>
        <field name="create_date"/>
      </list>
    </field>
  </record>

  <record id="view_oae_ai_bridge_context_link_form" model="ir.ui.view">
    <field name="name">oae.ai.bridge.context.link.form</field>
    <field name="model">oae.ai.bridge.context.link</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="model_name"/>
            <field name="res_id"/>
            <field name="build_request_id"/>
            <field name="requested_by_id"/>
            <field name="ai_console_url"/>
            <field name="notes"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_oae_ai_bridge_context_links" model="ir.actions.act_window">
    <field name="name">AI Bridge Context Links</field>
    <field name="res_model">oae.ai.bridge.context.link</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
